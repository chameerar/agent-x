# Copy to .env and adjust. `docker compose` reads .env automatically.

# Tool-capable Ollama model to pull and run.
#   qwen2.5:3b  - small & fast, good on CPU-only (all-in-Docker default)
#   qwen2.5     - 7B, noticeably better at multi-step tool use; slow on CPU
MODEL=qwen2.5:3b

# Host port for the web UI (mapped to 127.0.0.1 only).
PORT=8080

# Where the agent finds Ollama. Comment this out for the bundled
# `--profile bundled` run; keep it to use an Ollama you already run on the host.
OLLAMA_HOST=http://host.docker.internal:11434

# Export traces to Jaeger: set OTEL=true AND run with `--profile tracing`, then
# open the Jaeger UI at http://localhost:16686.
# OTEL=true
